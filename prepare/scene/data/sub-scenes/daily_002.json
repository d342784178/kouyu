      "estimatedMinutes": 5,
      "qaPairs": [
        {
          "id": "daily_002_sub_2_qa_1",
          "subSceneId": "daily_002_sub_2",
          "dialogueMode": "user_asks",
          "triggerText": "Is this yogurt sold by the pound or by the container?",
          "triggerTextCn": "这个酸奶是按磅卖还是按盒卖？",
