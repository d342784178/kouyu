        {
          "id": "daily_002_sub_4_qa_2",
          "subSceneId": "daily_002_sub_4",
          "dialogueMode": "user_asks",
          "triggerText": "Which line is moving fastest right now?",
          "triggerTextCn": "现在哪条队伍最快？",
          "triggerSpeakerRole": "staff",
          "scenarioHint": null,
          "scenarioHintCn": "顾客询问，工作人员指引",
          "followUps": [
            {
              "text": "The self-checkout — only two people ahead.",
              "text_cn": "自助结账，前面只有两人。",
              "audio_url": "COS:/qa/responses/daily_002_sub_4_qa_2_response0.mp3"
            },
            {
              "text": "Avoid the one with the elderly lady — she's paying with cash.",
              "text_cn": "别排那位老人的队，他付现金。",
              "audio_url": "COS:/qa/responses/daily_002_sub_4_qa_2_response1.mp3"
