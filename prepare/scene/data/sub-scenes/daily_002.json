          "scenarioHint": null,
          "scenarioHintCn": "顾客在超市寻找商品时，需要了解商品的计量单位，因此先提问。",
          "followUps": [
            {
              "text": "It's sold by the container — each one is 16 ounces.",
              "text_cn": "按盒卖，每盒16盎司。",
              "audio_url": "COS:/qa/responses/daily_002_sub_2_qa_1_response0.mp3"
            },
            {
              "text": "You can buy them in packs of four.",
              "text_cn": "可以四盒一起买。",
              "audio_url": "COS:/qa/responses/daily_002_sub_2_qa_1_response1.mp3"
            },
            {
              "text": "Just grab one — they're all the same size.",
              "text_cn": "拿一盒就行，都一样大。",
              "audio_url": "COS:/qa/responses/daily_002_sub_2_qa_1_response2.mp3"
            }
          ],
          "usageNote": "确认商品计价单位",
          "audioUrl": "COS:/qa/questions/daily_002_sub_2_qa_1.mp3",
          "learnRequirement": "speak_trigger",
          "order": 1
        },
        {
          "id": "daily_002_sub_2_qa_2",
          "subSceneId": "daily_002_sub_2",
          "dialogueMode": "user_asks",
          "triggerText": "How much does this bag of apples weigh?",
          "triggerTextCn": "这袋苹果有多重？",
          "triggerSpeakerRole": "staff",
          "scenarioHint": null,
          "scenarioHintCn": "顾客在超市寻找商品时，需要了解商品的计量单位，因此先提问。",
          "followUps": [
            {
              "text": "It's exactly 2 pounds — the scale shows it.",
              "text_cn": "正好两磅，秤上显示了。",
              "audio_url": "COS:/qa/responses/daily_002_sub_2_qa_2_response0.mp3"
            },
            {
              "text": "You can pick your own — they're sold by weight.",
              "text_cn": "你可以自己挑，按重量计价。",
              "audio_url": "COS:/qa/responses/daily_002_sub_2_qa_2_response1.mp3"
            },
            {
              "text": "Pre-packaged — 1.5 lbs each.",
              "text_cn": "预包装的，每袋1.5磅。",
              "audio_url": "COS:/qa/responses/daily_002_sub_2_qa_2_response2.mp3"
            }
          ],
          "usageNote": "询问散装商品重量",
          "audioUrl": "COS:/qa/questions/daily_002_sub_2_qa_2.mp3",
          "learnRequirement": "speak_trigger",
          "order": 2
        }
      ]
    },
    {
      "id": "daily_002_sub_3",
      "sceneId": "daily_002",
      "name": "询问促销活动",
      "description": "确认商品是否有折扣或赠品",
      "order": 3,
      "estimatedMinutes": 5,
      "qaPairs": [
        {
          "id": "daily_002_sub_3_qa_1",
          "subSceneId": "daily_002_sub_3",
