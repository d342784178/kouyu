          "scenarioHint": null,
          "scenarioHintCn": "顾客在超市寻找商品时，需要询问工作人员商品位置",
          "followUps": [
            {
              "text": "It's down the aisle to the left, next to the eggs.",
              "text_cn": "在左边过道，挨着鸡蛋那边。",
              "audio_url": "COS:/qa/responses/daily_002_sub_1_qa_1_response0.mp3"
            },
            {
              "text": "Just go straight and turn left at the produce section.",
              "text_cn": "直走，到蔬果区左转。",
              "audio_url": "COS:/qa/responses/daily_002_sub_1_qa_1_response1.mp3"
            },
            {
              "text": "Over there, near the cheese.",
              "text_cn": "那边，奶酪附近。",
              "audio_url": "COS:/qa/responses/daily_002_sub_1_qa_1_response2.mp3"
            }
          ],
          "usageNote": "用于询问商品具体位置",
          "audioUrl": "COS:/qa/questions/daily_002_sub_1_qa_1.mp3",
          "learnRequirement": "speak_trigger",
          "order": 1
        },
        {
          "id": "daily_002_sub_1_qa_2",
          "subSceneId": "daily_002_sub_1",
          "dialogueMode": "user_asks",
          "triggerText": "Do you have almond milk in the refrigerated section?",
          "triggerTextCn": "冷藏区有杏仁奶吗？",
          "triggerSpeakerRole": "staff",
          "scenarioHint": null,
          "scenarioHintCn": "顾客在超市寻找商品时，需要询问工作人员商品位置",
          "followUps": [
            {
              "text": "Yes, it's on the bottom shelf, next to the soy milk.",
              "text_cn": "有，在最下层，挨着豆浆。",
              "audio_url": "COS:/qa/responses/daily_002_sub_1_qa_2_response0.mp3"
            },
            {
              "text": "Sorry, we're out of stock right now.",
              "text_cn": "抱歉，现在缺货。",
              "audio_url": "COS:/qa/responses/daily_002_sub_1_qa_2_response1.mp3"
            },
            {
              "text": "Try the organic aisle, aisle 5.",
              "text_cn": "试试有机区，5号通道。",
              "audio_url": "COS:/qa/responses/daily_002_sub_1_qa_2_response2.mp3"
            }
          ],
          "usageNote": "确认特定商品是否在售",
          "audioUrl": "COS:/qa/questions/daily_002_sub_1_qa_2.mp3",
          "learnRequirement": "speak_trigger",
          "order": 2
        }
      ]
    },
    {
      "id": "daily_002_sub_2",
      "sceneId": "daily_002",
      "name": "确认计量单位",
      "description": "确认商品是按公斤还是按袋卖",
