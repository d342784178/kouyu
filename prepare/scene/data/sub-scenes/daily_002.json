          "triggerTextCn": "今天面包有促销吗？",
          "triggerSpeakerRole": "staff",
          "scenarioHint": null,
          "scenarioHintCn": "顾客询问，工作人员回答促销详情",
          "followUps": [
            {
              "text": "Yes! Buy one, get one half off — it's on the end cap.",
              "text_cn": "有！买一送半价，在端架上。",
              "audio_url": "COS:/qa/responses/daily_002_sub_3_qa_1_response0.mp3"
            },
            {
              "text": "No deals right now, but it's usually cheaper on Wednesdays.",
              "text_cn": "现在没有，周三通常便宜。",
              "audio_url": "COS:/qa/responses/daily_002_sub_3_qa_1_response1.mp3"
            },
            {
              "text": "Try the loyalty app — you get 10% off if you scan it.",
              "text_cn": "用会员App扫一下，打九折。",
              "audio_url": "COS:/qa/responses/daily_002_sub_3_qa_1_response2.mp3"
            }
          ],
          "usageNote": "询问商品促销信息",
          "audioUrl": "COS:/qa/questions/daily_002_sub_3_qa_1.mp3",
          "learnRequirement": "speak_trigger",
          "order": 1
        },
        {
          "id": "daily_002_sub_3_qa_2",
          "subSceneId": "daily_002_sub_3",
          "dialogueMode": "user_asks",
          "triggerText": "Do you have any coupons for cereal?",
          "triggerTextCn": "有麦片的优惠券吗？",
          "triggerSpeakerRole": "staff",
          "scenarioHint": null,
          "scenarioHintCn": "顾客询问，工作人员回答促销详情",
          "followUps": [
            {
              "text": "They're at the front near the checkout — grab one!",
              "text_cn": "收银台附近有，自己拿一份！",
              "audio_url": "COS:/qa/responses/daily_002_sub_3_qa_2_response0.mp3"
            },
            {
              "text": "Not today, but we're running a buy-3-get-1-free.",
              "text_cn": "今天没有，但有买三送一。",
              "audio_url": "COS:/qa/responses/daily_002_sub_3_qa_2_response1.mp3"
            },
            {
              "text": "You can download them from our website.",
              "text_cn": "可以去官网下载。",
              "audio_url": "COS:/qa/responses/daily_002_sub_3_qa_2_response2.mp3"
            }
          ],
          "usageNote": "索取或确认优惠券",
          "audioUrl": "COS:/qa/questions/daily_002_sub_3_qa_2.mp3",
          "learnRequirement": "speak_trigger",
          "order": 2
        }
      ]
    },
    {
