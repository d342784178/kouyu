      "qaPairs": [
        {
          "id": "daily_005_sub_1_qa_1",
          "subSceneId": "daily_005_sub_1",
          "dialogueMode": "user_responds",
          "triggerText": "Hi, I'm here for my appointment. My name's Tom Chen.",
          "triggerTextCn": "嗨，我来就诊，我叫汤姆·陈。",
          "triggerSpeakerRole": "staff",
          "scenarioHint": null,
          "scenarioHintCn": null,
          "followUps": [
            {
              "text": "Yeah, I'm Tom Chen. I booked at 3 PM.",
              "text_cn": "对，我叫汤姆·陈，三点约的。",
              "audio_url": "COS:/qa/responses/daily_005_sub_1_qa_1_response0.mp3"
            },
            {
              "text": "Good afternoon. I'm Tom Chen, scheduled for a checkup.",
              "text_cn": "下午好，我是汤姆·陈，预约了体检。",
              "audio_url": "COS:/qa/responses/daily_005_sub_1_qa_1_response1.mp3"
            },
            {
              "text": "Tom Chen. Appointment's at three.",
              "text_cn": "汤姆·陈，三点预约。",
              "audio_url": ""
            }
          ],
          "usageNote": "用简短句快速报姓名和时间",
          "audioUrl": "COS:/qa/questions/daily_005_sub_1_qa_1.mp3",
          "learnRequirement": "speak_followup",
          "order": 1
        }
      ]
    },
    {
      "id": "daily_005_sub_2",
      "sceneId": "daily_005",
      "name": "描述症状",
      "description": "向医生说明身体不适的具体表现",
      "order": 2,
      "estimatedMinutes": 5,
      "qaPairs": [
        {
          "id": "daily_005_sub_2_qa_1",
          "subSceneId": "daily_005_sub_2",
          "dialogueMode": "user_responds",
          "triggerText": "So, what's been going on?",
          "triggerTextCn": "那你最近哪儿不舒服？",
          "triggerSpeakerRole": "staff",
          "scenarioHint": null,
          "scenarioHintCn": null,
          "followUps": [
            {
              "text": "I've had a bad headache for two days, and my neck's stiff.",
              "text_cn": "我头疼两天了，脖子也僵硬。",
              "audio_url": "COS:/qa/responses/daily_005_sub_2_qa_1_response0.mp3"
            },
            {
              "text": "My head's killing me since Monday, and I can't turn my neck.",
              "text_cn": "从周一就开始头痛，脖子都转不动了。",
              "audio_url": "COS:/qa/responses/daily_005_sub_2_qa_1_response1.mp3"
            },
            {
              "text": "Headache + stiff neck. Two days.",
              "text_cn": "头疼加脖子僵，两天了。",
              "audio_url": ""
            }
          ],
          "usageNote": "用具体时间+身体部位描述症状",
          "audioUrl": "COS:/qa/questions/daily_005_sub_2_qa_1.mp3",
          "learnRequirement": "speak_followup",
          "order": 1
        },
        {
          "id": "daily_005_sub_2_qa_2",
          "subSceneId": "daily_005_sub_2",
          "dialogueMode": "user_responds",
          "triggerText": "Any fever or nausea?",
          "triggerTextCn": "有发烧或恶心吗？",
          "triggerSpeakerRole": "staff",
          "scenarioHint": null,
          "scenarioHintCn": null,
          "followUps": [
            {
              "text": "No fever, but I feel kinda sick to my stomach.",
              "text_cn": "没发烧，但有点想吐。",
              "audio_url": "COS:/qa/responses/daily_005_sub_2_qa_2_response0.mp3"
            },
            {
              "text": "I didn't check my temperature, but yeah, I'm a bit nauseous.",
              "text_cn": "没量体温，不过确实有点恶心。",
              "audio_url": "COS:/qa/responses/daily_005_sub_2_qa_2_response1.mp3"
            },
            {
              "text": "No fever. Maybe a little nauseous.",
              "text_cn": "没发烧，可能有点恶心。",
              "audio_url": ""
            }
          ],
          "usageNote": "用but或yeah加强语气，更自然",
          "audioUrl": "COS:/qa/questions/daily_005_sub_2_qa_2.mp3",
          "learnRequirement": "speak_followup",
          "order": 2
        }
      ]
    },
    {
      "id": "daily_005_sub_3",
      "sceneId": "daily_005",
      "name": "回答病史",
      "description": "医生询问过往病史或生活习惯",
      "order": 3,
      "estimatedMinutes": 5,
      "qaPairs": [
        {
          "id": "daily_005_sub_3_qa_1",
          "subSceneId": "daily_005_sub_3",
          "dialogueMode": "user_responds",
          "triggerText": "Do you smoke or drink much?",
          "triggerTextCn": "你抽烟或喝酒多吗？",
          "triggerSpeakerRole": "staff",
          "scenarioHint": null,
          "scenarioHintCn": null,
          "followUps": [
            {
              "text": "I used to smoke, but I quit last year. I drink wine once a week.",
              "text_cn": "以前抽，去年戒了，每周喝点红酒。",
              "audio_url": "COS:/qa/responses/daily_005_sub_3_qa_1_response0.mp3"
            },
            {
              "text": "Nah, I don't smoke. Just a beer on weekends.",
              "text_cn": "不抽，周末偶尔喝瓶啤酒。",
              "audio_url": "COS:/qa/responses/daily_005_sub_3_qa_1_response1.mp3"
            },
            {
              "text": "No smoking. Rarely drink.",
              "text_cn": "不抽烟，很少喝酒。",
              "audio_url": ""
            }
          ],
          "usageNote": "用used to / nah / rarelly体现不同语气",
          "audioUrl": "COS:/qa/questions/daily_005_sub_3_qa_1.mp3",
          "learnRequirement": "speak_followup",
          "order": 1
        },
        {
          "id": "daily_005_sub_3_qa_2",
          "subSceneId": "daily_005_sub_3",
          "dialogueMode": "user_responds",
          "triggerText": "Any allergies or chronic conditions?",
          "triggerTextCn": "有过敏或慢性病吗？",
          "triggerSpeakerRole": "staff",
          "scenarioHint": null,
          "scenarioHintCn": null,
          "followUps": [
            {
              "text": "I'm allergic to penicillin. No other issues.",
              "text_cn": "我对青霉素过敏，没别的问题。",
              "audio_url": "COS:/qa/responses/daily_005_sub_3_qa_2_response0.mp3"
            },
            {
              "text": "Yeah, penicillin makes me break out. Otherwise, I'm good.",
              "text_cn": "对，青霉素会让我起疹子，其他都还好。",
              "audio_url": "COS:/qa/responses/daily_005_sub_3_qa_2_response1.mp3"
            },
            {
              "text": "Penicillin allergy. Nothing else.",
              "text_cn": "青霉素过敏，没别的。",
              "audio_url": ""
            }
          ],
          "usageNote": "用makes me break out更口语化",
          "audioUrl": "COS:/qa/questions/daily_005_sub_3_qa_2.mp3",
          "learnRequirement": "speak_followup",
          "order": 2
        }
      ]
    },
    {
      "id": "daily_005_sub_4",
      "sceneId": "daily_005",
      "name": "获取医嘱",
      "description": "医生给出治疗建议和注意事项",
      "order": 4,
      "estimatedMinutes": 5,
      "qaPairs": [
        {
          "id": "daily_005_sub_4_qa_1",
          "subSceneId": "daily_005_sub_4",
          "dialogueMode": "user_responds",
          "triggerText": "You're probably just stressed. Rest up, drink water, and take this painkiller.",
          "triggerTextCn": "你可能是压力大，多休息、多喝水，吃这个止痛药。",
          "triggerSpeakerRole": "staff",
          "scenarioHint": null,
          "scenarioHintCn": null,
          "followUps": [
            {
              "text": "Got it. Should I avoid caffeine?",
              "text_cn": "明白，我该避免咖啡因吗？",
              "audio_url": "COS:/qa/responses/daily_005_sub_4_qa_1_response0.mp3"
            },
            {
              "text": "Okay, thanks. Is coffee okay?",
              "text_cn": "好的，谢谢，咖啡能喝吗？",
              "audio_url": "COS:/qa/responses/daily_005_sub_4_qa_1_response1.mp3"
            },
            {
              "text": "Thanks. No coffee?",
              "text_cn": "谢谢，不能喝咖啡？",
              "audio_url": ""
            }
          ],
          "usageNote": "用Got it / Okay / Thanks开头，自然回应",
          "audioUrl": "COS:/qa/questions/daily_005_sub_4_qa_1.mp3",
          "learnRequirement": "speak_followup",
          "order": 1
        },
        {
          "id": "daily_005_sub_4_qa_2",
          "subSceneId": "daily_005_sub_4",
          "dialogueMode": "user_responds",
          "triggerText": "Come back if it gets worse in 48 hours.",
          "triggerTextCn": "48小时后如果更糟，就回来复诊。",
          "triggerSpeakerRole": "staff",
          "scenarioHint": null,
          "scenarioHintCn": null,
          "followUps": [
            {
              "text": "Will do. Thanks so much!",
              "text_cn": "好的，太感谢了！",
              "audio_url": "COS:/qa/responses/daily_005_sub_4_qa_2_response0.mp3"
            },
            {
              "text": "Okay, I'll call if it doesn't improve.",
              "text_cn": "好，没好转我就打电话。",
              "audio_url": "COS:/qa/responses/daily_005_sub_4_qa_2_response1.mp3"
            },
            {
              "text": "Understood.",
              "text_cn": "明白了。",
              "audio_url": ""
            }
          ],
          "usageNote": "用Will do最地道，Understood最简短",
          "audioUrl": "COS:/qa/questions/daily_005_sub_4_qa_2.mp3",
          "learnRequirement": "speak_followup",
          "order": 2
        }
      ]
    },
    {
      "id": "daily_005_sub_5",
      "sceneId": "daily_005",
