        {
          "id": "travel_073_sub_2_qa_1",
          "subSceneId": "travel_073_sub_2",
          "dialogueMode": "user_asks",
          "triggerText": "You need to change at Green Park. The train heads north from there.",
          "triggerTextCn": "您需要在绿园站换乘，之后列车往北开。",
          "triggerSpeakerRole": "staff",
          "scenarioHint": null,
          "scenarioHintCn": "例如：Excuse me, could you tell me how to get to Green Park?",
          "followUps": [
            {
              "text": "Wait, is that the same platform or do I go upstairs?",
              "text_cn": "等等，是同站台换乘还是得上楼？",
              "audio_url": "COS:/qa/responses/travel_073_sub_2_qa_1_response0.mp3"
            },
            {
              "text": "North? I thought it went west...",
              "text_cn": "往北？我以为是往西啊...",
