          "usageNote": "礼貌询问目的地路线",
          "audioUrl": "COS:/qa/questions/travel_073_sub_1_qa_1.mp3",
          "learnRequirement": "speak_followup",
          "order": 1
        },
        {
          "id": "travel_073_sub_1_qa_2",
          "subSceneId": "travel_073_sub_1",
          "dialogueMode": "user_responds",
          "triggerText": "Sure! Take Line 2 towards East Station, then switch to Line 5 at Central Plaza.",
          "triggerTextCn": "当然！坐2号线往东站方向，在中央广场换5号线。",
          "triggerSpeakerRole": "staff",
          "scenarioHint": null,
          "scenarioHintCn": null,
          "followUps": [
            {
              "text": "Thanks! Is Line 5 going directly to the city center?",
              "text_cn": "谢谢！5号线直接到市中心吗？",
              "audio_url": "COS:/qa/responses/travel_073_sub_1_qa_2_response0.mp3"
            },
            {
              "text": "Got it. And how many stops?",
              "text_cn": "明白了，要坐几站？",
              "audio_url": "COS:/qa/responses/travel_073_sub_1_qa_2_response1.mp3"
            }
          ],
          "usageNote": "确认换乘和站点数量",
          "audioUrl": "COS:/qa/questions/travel_073_sub_1_qa_2.mp3",
          "learnRequirement": "speak_followup",
