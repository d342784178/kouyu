          "subSceneId": "travel_073_sub_1",
          "dialogueMode": "user_responds",
          "triggerText": "Hi there! How can I help you today?",
          "triggerTextCn": "您好！有什么可以帮您的吗？",
          "triggerSpeakerRole": "staff",
          "scenarioHint": null,
          "scenarioHintCn": null,
          "followUps": [
            {
              "text": "Hi! Could you tell me how to get to the city center?",
              "text_cn": "你好！能告诉我怎么去市中心吗？",
              "audio_url": "COS:/qa/responses/travel_073_sub_1_qa_1_response0.mp3"
            },
            {
              "text": "Excuse me, where's the way to downtown?",
              "text_cn": "不好意思，去市中心怎么走？",
              "audio_url": "COS:/qa/responses/travel_073_sub_1_qa_1_response1.mp3"
            }
