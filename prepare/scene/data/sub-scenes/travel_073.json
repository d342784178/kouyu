          "subSceneId": "travel_073_sub_3",
          "dialogueMode": "user_responds",
          "triggerText": "Yes, no transfers needed. Just stay on until you hear 'Museum Station, last stop'.",
          "triggerTextCn": "是的，不用换乘，听到‘博物馆站，终点站’再下车。",
          "triggerSpeakerRole": "staff",
          "scenarioHint": null,
          "scenarioHintCn": null,
          "followUps": [
            {
              "text": "Perfect! Thanks so much for your help!",
              "text_cn": "太好了！非常感谢您的帮助！",
              "audio_url": "COS:/qa/responses/travel_073_sub_3_qa_2_response0.mp3"
            },
            {
              "text": "I’ll listen for that. You’re a lifesaver!",
              "text_cn": "我会注意听的，你真是帮了大忙！",
              "audio_url": "COS:/qa/responses/travel_073_sub_3_qa_2_response1.mp3"
