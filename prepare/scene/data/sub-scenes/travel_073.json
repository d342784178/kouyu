          "subSceneId": "travel_073_sub_3",
          "dialogueMode": "user_responds",
          "triggerText": "This train goes all the way to Museum Station. Last stop!",
          "triggerTextCn": "这趟车直达博物馆站，是终点站。",
          "triggerSpeakerRole": "staff",
          "scenarioHint": null,
          "scenarioHintCn": null,
          "followUps": [
            {
              "text": "Is this the last stop? I don’t want to miss it.",
              "text_cn": "这是终点站吗？我怕坐过站。",
              "audio_url": "COS:/qa/responses/travel_073_sub_3_qa_1_response0.mp3"
            },
            {
              "text": "Great! Can I stay seated the whole time?",
              "text_cn": "太好了！我可以一路坐着不换吗？",
