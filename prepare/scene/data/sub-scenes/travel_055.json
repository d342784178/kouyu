    },
    {
      "id": "travel_055_sub_4",
      "name": "道谢告别",
      "description": "表达感谢并礼貌结束对话",
      "estimatedMinutes": 5,
      "qaPairs": [
        {
          "id": "travel_055_sub_4_qa_1",
          "qaType": "listen_only",
          "speakerText": "Thanks so much for your help!",
          "speakerTextCn": "非常感谢你的帮助！",
          "responses": [
            {
              "text": "You're welcome! Have a great day!",
              "text_cn": "不客气，祝你今天愉快！",
              "audio_url": "COS:/qa/responses/travel_055_sub_4_qa_1_response0.mp3"
            },
            {
              "text": "No problem, enjoy the museum!",
              "text_cn": "没事，好好参观博物馆吧！",
              "audio_url": "COS:/qa/responses/travel_055_sub_4_qa_1_response1.mp3"
            },
            {
              "text": "Anytime!",
              "text_cn": "随时欢迎！",
              "audio_url": "COS:/qa/responses/travel_055_sub_4_qa_1_response2.mp3"
