{
  "sceneId": "travel_055",
  "sceneName": "问路导航",
  "subScenes": [
    {
      "id": "travel_055_sub_1",
      "name": "礼貌打招呼",
      "description": "礼貌打断路人开始问路",
      "estimatedMinutes": 5,
      "qaPairs": [
        {
          "id": "travel_055_sub_1_qa_1",
          "qaType": "must_speak",
          "speakerText": "Excuse me, could I ask for a quick favor?",
          "speakerTextCn": "不好意思，能麻烦您一下吗？",
          "responses": [
            {
              "text": "Of course, what can I help you with?",
              "text_cn": "当然，有什么可以帮您的？",
              "audio_url": "COS:/qa/responses/travel_055_sub_1_qa_1_response0.mp3"
            },
            {
              "text": "Sure, go ahead.",
              "text_cn": "当然，说吧。",
              "audio_url": "COS:/qa/responses/travel_055_sub_1_qa_1_response1.mp3"
            },
            {
              "text": "Yeah, what is it?",
              "text_cn": "嗯，什么事？",
              "audio_url": "COS:/qa/responses/travel_055_sub_1_qa_1_response2.mp3"
            }
          ],
          "usageNote": "用于礼貌开启问路对话"
        },
        {
          "id": "travel_055_sub_1_qa_2",
          "qaType": "must_speak",
          "speakerText": "I'm looking for the nearest subway station. Could you point me in the right direction?",
          "speakerTextCn": "我在找最近的地铁站，您能指一下方向吗？",
          "responses": [
            {
              "text": "",
              "text_cn": "",
              "audio_url": "COS:/qa/responses/travel_055_sub_1_qa_2_response0.mp3"
            },
            {
              "text": "",
              "text_cn": "",
              "audio_url": "COS:/qa/responses/travel_055_sub_1_qa_2_response1.mp3"
            }
          ],
          "usageNote": "询问具体地点的标准表达"
        },
        {
          "id": "travel_055_sub_1_qa_3",
          "qaType": "must_speak",
          "speakerText": "Sorry, I'm not from around here either. I'm not sure.",
          "speakerTextCn": "抱歉，我也不是本地人，我不太确定。",
          "responses": [
            {
              "text": "",
              "text_cn": "",
              "audio_url": "COS:/qa/responses/travel_055_sub_1_qa_3_response0.mp3"
            },
            {
              "text": "",
              "text_cn": "",
              "audio_url": "COS:/qa/responses/travel_055_sub_1_qa_3_response1.mp3"
            }
          ],
          "usageNote": "对方不知道时的应对"
        },
        {
          "id": "travel_055_sub_1_qa_4",
          "qaType": "listen_only",
          "speakerText": "You can also use Google Maps — it's very accurate around here.",
          "speakerTextCn": "您也可以用谷歌地图，这附近很准确。",
          "responses": [
            {
              "text": "",
              "text_cn": "",
              "audio_url": "COS:/qa/responses/travel_055_sub_1_qa_4_response0.mp3"
            }
          ],
          "usageNote": "对方建议使用导航软件"
        }
      ]
    },
    {
      "id": "travel_055_sub_2",
      "name": "询问目的地",
      "description": "清楚说出你要去的地方",
      "estimatedMinutes": 5,
      "qaPairs": [
        {
          "id": "travel_055_sub_2_qa_2",
          "qaType": "must_speak",
          "speakerText": "That's right. You'll see a big fountain — that's the landmark.",
          "speakerTextCn": "对的。您会看到一个大喷泉，那就是地标。",
          "responses": [
            {
              "text": "",
              "text_cn": "",
              "audio_url": "COS:/qa/responses/travel_055_sub_2_qa_2_response0.mp3"
            },
            {
              "text": "",
              "text_cn": "",
              "audio_url": "COS:/qa/responses/travel_055_sub_2_qa_2_response1.mp3"
            }
          ],
          "usageNote": "确认地标帮助辨认方向"
        },
        {
          "id": "travel_055_sub_2_qa_1",
          "qaType": "must_speak",
          "speakerText": "Do you know how to get to the Central Museum?",
          "speakerTextCn": "你知道怎么去中央博物馆吗？",
          "responses": [
            {
              "text": "Yes, it's just two blocks north on Main Street.",
              "text_cn": "知道，沿着主街向北两个街区。",
              "audio_url": "COS:/qa/responses/travel_055_sub_2_qa_1_response0.mp3"
            },
            {
              "text": "Sorry, I'm not from around here.",
              "text_cn": "抱歉，我不是本地人。",
              "audio_url": "COS:/qa/responses/travel_055_sub_2_qa_1_response1.mp3"
            },
            {
              "text": "Walk straight, then turn left at the bank.",
              "text_cn": "直走，到银行左转。",
              "audio_url": "COS:/qa/responses/travel_055_sub_2_qa_1_response2.mp3"
            }
          ],
          "usageNote": "询问具体地点的常用句型"
        },
        {
          "id": "travel_055_sub_2_qa_3",
          "qaType": "must_speak",
          "speakerText": "It's about a 10-minute walk. You can't miss it.",
          "speakerTextCn": "大约走10分钟，您不会错过的。",
          "responses": [
            {
              "text": "",
              "text_cn": "",
              "audio_url": "COS:/qa/responses/travel_055_sub_2_qa_3_response0.mp3"
            },
            {
              "text": "",
              "text_cn": "",
              "audio_url": "COS:/qa/responses/travel_055_sub_2_qa_3_response1.mp3"
            }
          ],
          "usageNote": "询问距离和时间"
        },
        {
          "id": "travel_055_sub_2_qa_4",
          "qaType": "must_speak",
          "speakerText": "You're welcome! Enjoy your visit!",
          "speakerTextCn": "不客气！祝您参观愉快！",
          "responses": [
            {
              "text": "",
              "text_cn": "",
              "audio_url": "COS:/qa/responses/travel_055_sub_2_qa_4_response0.mp3"
            },
            {
              "text": "",
              "text_cn": "",
              "audio_url": "COS:/qa/responses/travel_055_sub_2_qa_4_response1.mp3"
            }
          ],
          "usageNote": "道谢后的礼貌回应"
        }
      ]
    },
    {
      "id": "travel_055_sub_3",
      "name": "确认方向",
      "description": "确认左右、前后等方位指引",
      "estimatedMinutes": 5,
      "qaPairs": [
        {
          "id": "travel_055_sub_3_qa_3",
          "qaType": "must_speak",
          "speakerText": "In that case, you need to turn around and walk back about 200 meters.",
          "speakerTextCn": "那样的话，您需要转身往回走大约200米。",
          "responses": [
            {
              "text": "",
              "text_cn": "",
              "audio_url": "COS:/qa/responses/travel_055_sub_3_qa_3_response0.mp3"
            },
            {
              "text": "",
              "text_cn": "",
              "audio_url": "COS:/qa/responses/travel_055_sub_3_qa_3_response1.mp3"
            }
          ],
          "usageNote": "走错方向时的纠正指引"
        },
        {
          "id": "travel_055_sub_3_qa_1",
          "qaType": "must_speak",
          "speakerText": "Is it far from here? And do I turn left or right after the post office?",
          "speakerTextCn": "离这儿远吗？过了邮局是左转还是右转？",
          "responses": [
            {
              "text": "It's about five minutes walk. Turn left after the post office.",
              "text_cn": "大概五分钟路程，邮局后左转。",
              "audio_url": "COS:/qa/responses/travel_055_sub_3_qa_1_response0.mp3"
            },
            {
              "text": "Not far, and yes, left at the post office.",
              "text_cn": "不远，邮局那儿左转。",
              "audio_url": "COS:/qa/responses/travel_055_sub_3_qa_1_response1.mp3"
            },
            {
              "text": "You're good, just keep going.",
              "text_cn": "没问题，一直走就行。",
              "audio_url": "COS:/qa/responses/travel_055_sub_3_qa_1_response2.mp3"
            }
          ],
          "usageNote": "确认方向和距离的关键提问"
        },
        {
          "id": "travel_055_sub_3_qa_4",
          "qaType": "listen_only",
          "speakerText": "No problem at all. It happens to everyone in a new city!",
          "speakerTextCn": "完全没问题。在陌生城市迷路是常有的事！",
          "responses": [
            {
              "text": "",
              "text_cn": "",
              "audio_url": "COS:/qa/responses/travel_055_sub_3_qa_4_response0.mp3"
            }
          ],
          "usageNote": "对方安慰的友好回应"
        },
        {
          "id": "travel_055_sub_3_qa_2",
          "qaType": "must_speak",
          "speakerText": "Is it far from here?",
          "speakerTextCn": "离这儿远吗？",
          "responses": [
            {
              "text": "",
              "text_cn": "",
              "audio_url": "COS:/qa/responses/travel_055_sub_3_qa_2_response0.mp3"
            },
